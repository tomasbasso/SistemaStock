@using Sistema_de_Stock.Services
@inject NotificationService NotificationService
@implements IDisposable

@if (_notifications.Any())
{
    <div class="toast-container" aria-live="polite" aria-atomic="true">
        @foreach (var n in _notifications)
        {
            <div class="toast @GetClass(n.Type)" @key="n.Id">
                <span class="toast-icon">@GetIcon(n.Type)</span>
                <span class="toast-message">@n.Message</span>
            </div>
        }
    </div>
}

@code {
    private readonly List<Notification> _notifications = new();

    protected override void OnInitialized()
    {
        NotificationService.OnNotify += HandleNotification;
    }

    private void HandleNotification(Notification notification)
    {
        InvokeAsync(async () =>
        {
            _notifications.Add(notification);
            StateHasChanged();

            // Auto-dismiss after 4 seconds
            await Task.Delay(4000);
            _notifications.Remove(notification);
            StateHasChanged();
        });
    }

    private static string GetClass(NotificationType type) => type switch
    {
        NotificationType.Success => "toast-success",
        NotificationType.Error   => "toast-error",
        NotificationType.Warning => "toast-warning",
        _                        => "toast-info"
    };

    private static string GetIcon(NotificationType type) => type switch
    {
        NotificationType.Success => "✓",
        NotificationType.Error   => "✕",
        NotificationType.Warning => "⚠",
        _                        => "ℹ"
    };

    public void Dispose()
    {
        NotificationService.OnNotify -= HandleNotification;
    }
}
