@page "/productos"
@using Sistema_de_Stock.Models
@using Sistema_de_Stock.Services
@using Sistema_de_Stock.Components.Shared
@inject DataService Data

<div class="max-w-7xl mx-auto">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
        <div>
            <h2 class="page-title mb-1">Inventario</h2>
            <p class="page-subtitle">Gestión de Productos y Stock</p>
        </div>
        <button @onclick="OpenNew" class="bg-[var(--color-primary)] hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2">
            <i class="bi bi-plus-lg"></i>
            <span>Nuevo Producto</span>
        </button>
    </div>

    <!-- Filters & Search -->
    <div class="premium-card p-4 mb-6 flex items-center">
        <div class="relative flex-1 max-w-md">
            <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Buscar por nombre, SKU o categoría..." class="w-full bg-black/20 border border-white/10 rounded-xl pl-12 pr-4 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)] transition-all" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="premium-card p-6 min-h-[400px] flex items-center justify-center">
            <i class="bi bi-arrow-repeat animate-spin text-4xl text-gray-500"></i>
        </div>
    }
    else if (!FilteredItems.Any() && string.IsNullOrWhiteSpace(searchQuery))
    {
        <div class="text-center py-20 bg-white/5 rounded-2xl border border-white/5 border-dashed">
            <i class="bi bi-box-seam text-4xl text-gray-400 mb-4 block"></i>
            <h3 class="text-lg font-medium text-white mb-2">Inventario Vacío</h3>
            <p class="text-gray-400 mb-6">Agrega productos para comenzar a operar.</p>
            <button @onclick="OpenNew" class="text-[var(--color-primary)] hover:text-white transition-colors">Crear Producto &rarr;</button>
        </div>
    }
    else
    {
        <div class="premium-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left whitespace-nowrap">
                    <thead>
                        <tr class="border-b border-white/10 bg-black/20 text-xs uppercase tracking-wider text-gray-400">
                            <th class="px-6 py-4 font-medium">SKU</th>
                            <th class="px-6 py-4 font-medium">Producto</th>
                            <th class="px-6 py-4 font-medium">Categoría</th>
                            <th class="px-6 py-4 font-medium text-right">Precio</th>
                            <th class="px-6 py-4 font-medium">Stock</th>
                            <th class="px-6 py-4 font-medium text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var item in PaginatedItems)
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4 text-sm font-mono text-gray-400">@(string.IsNullOrEmpty(item.SKU) ? "-" : item.SKU)</td>
                                <td class="px-6 py-4">
                                    <div class="font-medium text-white">@item.Name</div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-300">@GetCategoryName(item.CategoryId)</td>
                                <td class="px-6 py-4 text-sm text-right font-medium">@item.Price.ToString("C")</td>
                                <td class="px-6 py-4">
                                    @{
                                        string badgeClass = item.Stock <= 0 ? "bg-[var(--color-danger)]/20 text-[var(--color-danger)] border-[var(--color-danger)]/30" : 
                                                          (item.Stock <= item.StockMinimo ? "bg-[var(--color-warning)]/20 text-[var(--color-warning)] border-[var(--color-warning)]/30" : 
                                                          "bg-[var(--color-success)]/20 text-[var(--color-success)] border-[var(--color-success)]/30");
                                    }
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border @badgeClass">
                                        @item.Stock u.
                                    </span>
                                    @if(item.StockMinimo > 0)
                                    {
                                        <span class="text-[10px] text-gray-500 ml-2 block mt-1">Min: @item.StockMinimo</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button @onclick="() => OpenEdit(item)" class="w-8 h-8 rounded-md bg-white/5 text-gray-300 hover:text-white hover:bg-[var(--color-primary)] transition-colors flex items-center justify-center" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button @onclick="() => OpenDelete(item)" class="w-8 h-8 rounded-md bg-white/5 text-gray-300 hover:text-white hover:bg-[var(--color-danger)] transition-colors flex items-center justify-center" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if (!PaginatedItems.Any())
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                                    No se encontraron resultados para "@searchQuery"
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <AppPagination TotalItems="FilteredItems.Count" PageSize="20" CurrentPage="currentPage" OnPageChanged="HandlePageChange" />
        </div>
    }

</div>

<!-- Form Modal -->
<AppModal IsOpen="isModalOpen" IsOpenChanged="(v) => isModalOpen = v" Title="@(isEditMode ? "Editar Producto" : "Nuevo Producto")">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-300 mb-1">Nombre *</label>
            <input type="text" @bind="editingItem.Name" autofocus class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">SKU</label>
            <input type="text" @bind="editingItem.SKU" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Categoría *</label>
            <select @bind="editingItem.CategoryId" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]">
                <option value="@Guid.Empty" class="bg-[#161b27] text-white">-- Seleccionar --</option>
                @foreach (var c in categorias)
                {
                    <option value="@c.Id" class="bg-[#161b27] text-white">@c.Name</option>
                }
            </select>
        </div>
        
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Precio *</label>
            <input type="number" step="0.01" @bind="editingItem.Price" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>

        <div></div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Stock Actual</label>
            <input type="number" @bind="editingItem.Stock" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Stock Mínimo</label>
            <input type="number" @bind="editingItem.StockMinimo" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>

    </div>
    
    <div class="mt-8 flex justify-end gap-3">
        <button @onclick="() => isModalOpen = false" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors font-medium">Cancelar</button>
        <button @onclick="Save" disabled="@(!IsValid(editingItem))" class="px-5 py-2.5 rounded-xl bg-[var(--color-primary)] hover:brightness-110 text-white transition-all font-medium disabled:opacity-50 disabled:cursor-not-allowed">Guardar</button>
    </div>
</AppModal>

<!-- Delete Modal -->
<AppModal IsOpen="isDeleteModalOpen" IsOpenChanged="(v) => isDeleteModalOpen = v" Title="Corfirmar Eliminación">
    <div class="py-4">
        <p class="text-gray-300">¿Estás seguro de que deseas eliminar <strong>@deletingItem?.Name</strong>?</p>
        <p class="text-sm text-[var(--color-danger)] mt-2"><i class="bi bi-exclamation-triangle-fill mr-1"></i> Esta acción no se puede deshacer.</p>
    </div>
    <div class="mt-6 flex justify-end gap-3">
        <button @onclick="() => isDeleteModalOpen = false" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors font-medium">Cancelar</button>
        <button @onclick="ConfirmDelete" class="px-5 py-2.5 rounded-xl bg-[var(--color-danger)] hover:brightness-110 text-white transition-all font-medium">Eliminar</button>
    </div>
</AppModal>

@code {
    private List<Producto> allItems = new();
    private List<Categoria> categorias = new();
    private bool isLoading = true;
    
    // Search & Pagination
    private string _searchQuery = "";
    private string searchQuery 
    {
        get => _searchQuery;
        set 
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                currentPage = 1; // Reset to page 1 on search
            }
        }
    }
    
    private int currentPage = 1;
    private int pageSize = 20;

    private List<Producto> FilteredItems => string.IsNullOrWhiteSpace(searchQuery) 
        ? allItems 
        : allItems.Where(x => 
            x.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
            x.SKU.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            GetCategoryName(x.CategoryId).Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
          ).ToList();

    private IEnumerable<Producto> PaginatedItems => FilteredItems.Skip((currentPage - 1) * pageSize).Take(pageSize);

    // Modals
    private bool isModalOpen = false;
    private bool isDeleteModalOpen = false;
    private bool isEditMode = false;
    private Producto editingItem = new();
    private Producto? deletingItem;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        categorias = await Data.GetCategoriasAsync();
        allItems = (await Data.GetProductosAsync()).OrderBy(x => x.Name).ToList();
        isLoading = false;
    }

    private string GetCategoryName(Guid id)
    {
        var cat = categorias.FirstOrDefault(c => c.Id == id);
        return cat?.Name ?? "Sin Categoría";
    }

    private void HandlePageChange(int page)
    {
        currentPage = page;
    }

    private bool IsValid(Producto p)
    {
        return !string.IsNullOrWhiteSpace(p.Name) && p.CategoryId != Guid.Empty && p.Price >= 0;
    }

    private void OpenNew()
    {
        editingItem = new Producto();
        isEditMode = false;
        isModalOpen = true;
    }

    private void OpenEdit(Producto item)
    {
        editingItem = new Producto 
        { 
            Id = item.Id, 
            Name = item.Name, 
            SKU = item.SKU, 
            CategoryId = item.CategoryId, 
            Price = item.Price, 
            Stock = item.Stock, 
            StockMinimo = item.StockMinimo 
        };
        isEditMode = true;
        isModalOpen = true;
    }

    private async Task Save()
    {
        if (!IsValid(editingItem)) return;
        
        await Data.SaveProductoAsync(editingItem);
        isModalOpen = false;
        await LoadData();
    }

    private void OpenDelete(Producto item)
    {
        deletingItem = item;
        isDeleteModalOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (deletingItem != null)
        {
            await Data.DeleteProductoAsync(deletingItem.Id);
            isDeleteModalOpen = false;
            await LoadData();
        }
    }
}
