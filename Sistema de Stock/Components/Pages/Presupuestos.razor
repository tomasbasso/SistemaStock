@page "/presupuestos"
@using Sistema_de_Stock.Models
@using Sistema_de_Stock.Services
@using Sistema_de_Stock.Components.Shared
@inject DataService Data
@inject PdfService PdfSvc
@inject NotificationService Notifications

<div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
        <div>
            <h2 class="page-title mb-1">Presupuestos</h2>
            <p class="page-subtitle">Generá y descargá presupuestos en PDF</p>
        </div>
        <button @onclick="OpenNuevo" class="bg-[var(--color-primary)] hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center gap-2">
            <i class="bi bi-plus-lg"></i>
            <span>Nuevo Presupuesto</span>
        </button>
    </div>

    @if (isLoading)
    {
        <div class="premium-card p-6 min-h-[300px] flex items-center justify-center">
            <i class="bi bi-arrow-repeat animate-spin text-4xl text-gray-500"></i>
        </div>
    }
    else if (!presupuestos.Any())
    {
        <div class="text-center py-20 bg-white/5 rounded-2xl border border-white/5 border-dashed">
            <i class="bi bi-file-earmark-text text-4xl text-gray-400 mb-4 block"></i>
            <h3 class="text-lg font-medium text-white mb-2">Sin presupuestos</h3>
            <p class="text-gray-400 mb-6">Crea el primer presupuesto para enviárselo a un cliente.</p>
            <button @onclick="OpenNuevo" class="text-[var(--color-primary)] hover:text-white transition-colors">Crear Presupuesto &rarr;</button>
        </div>
    }
    else
    {
        <div class="premium-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left whitespace-nowrap">
                    <thead>
                        <tr class="border-b border-white/10 bg-black/20 text-xs uppercase tracking-wider text-gray-400">
                            <th class="px-6 py-4 font-medium">N°</th>
                            <th class="px-6 py-4 font-medium">Fecha</th>
                            <th class="px-6 py-4 font-medium">Cliente</th>
                            <th class="px-6 py-4 font-medium">Vence</th>
                            <th class="px-6 py-4 font-medium text-right">Total</th>
                            <th class="px-6 py-4 font-medium text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var p in presupuestos)
                        {
                            bool vencido = p.FechaVencimiento.HasValue && p.FechaVencimiento.Value.Date < DateTime.Today;
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-6 py-4 font-mono text-sm text-gray-300">#@p.NumeroPresupuesto.ToString("D6")</td>
                                <td class="px-6 py-4 text-sm text-gray-300">@p.Date.ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 text-sm text-white">
                                    @if (p.ClienteId.HasValue)
                                    {
                                        @GetClienteName(p.ClienteId)
                                    }
                                    else
                                    {
                                        <span class="text-gray-500 italic">Sin cliente</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    @if (p.FechaVencimiento.HasValue)
                                    {
                                        <span class="@(vencido ? "text-[var(--color-danger)]" : "text-gray-300")">
                                            @p.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                            @if (vencido) { <span class="ml-1 text-xs">(vencido)</span> }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-600">—</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-right text-[var(--color-secondary)]">@p.Total.ToString("C")</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button @onclick="() => DescargarPdfAsync(p)"
                                                disabled="@(downloadingId == p.Id)"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-white/5 hover:bg-[var(--color-primary)] text-gray-300 hover:text-white transition-all disabled:opacity-50 border border-white/10 hover:border-transparent"
                                                title="Descargar PDF">
                                            @if (downloadingId == p.Id)
                                            {
                                                <i class="bi bi-arrow-repeat animate-spin"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-file-earmark-pdf-fill"></i>
                                            }
                                            <span>PDF</span>
                                        </button>
                                        <button @onclick="() => OpenEliminar(p)"
                                                class="w-8 h-8 rounded-md bg-white/5 text-gray-300 hover:text-white hover:bg-[var(--color-danger)] transition-colors flex items-center justify-center"
                                                title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal Nuevo Presupuesto -->
<AppModal IsOpen="isModalOpen" IsOpenChanged="(v) => isModalOpen = v" Title="Nuevo Presupuesto">
    <EditForm Model="nuevoPresupuesto" OnValidSubmit="GuardarYDescargarAsync">
        <DataAnnotationsValidator />

        <!-- Datos generales -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5">Cliente <span class="text-gray-600">(Opcional)</span></label>
                <InputSelect @bind-Value="nuevoPresupuesto.ClienteId" class="w-full bg-black/20 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)]">
                    <option value="">— Sin cliente —</option>
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => nuevoPresupuesto.ClienteId" class="text-[var(--color-danger)] text-xs mt-1" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5">Válido hasta <span class="text-gray-600">(Opcional)</span></label>
                <InputDate @bind-Value="nuevoPresupuesto.FechaVencimiento"
                           class="w-full bg-black/20 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)]" />
                <ValidationMessage For="() => nuevoPresupuesto.FechaVencimiento" class="text-[var(--color-danger)] text-xs mt-1" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-400 mb-1.5">Observaciones <span class="text-gray-600">(Opcional)</span></label>
                <InputText @bind-Value="nuevoPresupuesto.Notas" placeholder="Ej: No incluye IVA, incluye colocación..."
                           class="w-full bg-black/20 border border-white/10 rounded-xl px-3 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)]" />
                <ValidationMessage For="() => nuevoPresupuesto.Notas" class="text-[var(--color-danger)] text-xs mt-1" />
            </div>
        </div>

    <!-- Separador -->
    <div class="border-t border-white/10 mb-5"></div>

    <!-- Dos columnas: productos | items -->
    <div class="grid grid-cols-2 gap-5">

        <!-- Col izquierda: catálogo -->
        <div class="flex flex-col">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Catálogo de productos</p>
            <div class="relative mb-2">
                <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-xs"></i>
                <input type="text" @bind="productSearch" @bind:event="oninput"
                       placeholder="Buscar por nombre o SKU..."
                       class="w-full bg-black/20 border border-white/10 rounded-lg pl-8 pr-3 py-2 text-xs text-white focus:outline-none focus:border-[var(--color-primary)]" />
            </div>
            <div class="overflow-y-auto space-y-1 custom-scrollbar" style="max-height:280px">
                @foreach (var p in ProductosFiltrados)
                {
                    <div @onclick="() => AgregarProducto(p)"
                         class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white/5 hover:bg-[var(--color-primary)]/10 hover:border-[var(--color-primary)]/30 cursor-pointer transition-all border border-transparent group">
                        <div class="min-w-0 flex-1 pr-2">
                            <p class="text-sm text-white truncate group-hover:text-[var(--color-primary)] transition-colors">@p.Name</p>
                            <p class="text-xs text-gray-600 mt-0.5">@p.SKU</p>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <span class="text-sm font-semibold text-[var(--color-secondary)]">@p.Price.ToString("C")</span>
                            <div class="w-5 h-5 rounded-full bg-white/5 group-hover:bg-[var(--color-primary)] flex items-center justify-center transition-colors">
                                <i class="bi bi-plus text-gray-400 group-hover:text-white transition-colors" style="font-size:11px"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Col derecha: items seleccionados -->
        <div class="flex flex-col">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">
                Items del presupuesto
                @if (items.Any()) { <span class="ml-1 text-[var(--color-primary)]">(@items.Count)</span> }
            </p>

            @if (!items.Any())
            {
                <div class="flex-1 flex flex-col items-center justify-center py-10 bg-white/3 rounded-xl border border-white/5 border-dashed text-center" style="min-height:200px">
                    <i class="bi bi-cart-plus text-3xl text-gray-700 mb-2 block"></i>
                    <p class="text-sm text-gray-600">Seleccioná productos<br/>del catálogo</p>
                </div>
            }
            else
            {
                <div class="overflow-y-auto space-y-2 custom-scrollbar flex-1" style="max-height:240px">
                    @foreach (var item in items)
                    {
                        <div class="flex items-center gap-3 bg-white/5 rounded-xl px-3 py-2.5 border border-white/5">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-white truncate leading-tight">@item.Nombre</p>
                                <p class="text-xs text-gray-500 mt-0.5">@item.PrecioUnitario.ToString("C") × @item.Cantidad = <span class="text-gray-300 font-medium">@item.Subtotal.ToString("C")</span></p>
                            </div>
                            <div class="flex items-center bg-black/30 rounded-lg border border-white/10 flex-shrink-0">
                                <button @onclick="() => CambiarCantidad(item, -1)" class="w-7 h-7 flex items-center justify-center text-gray-400 hover:text-white transition-colors text-base">−</button>
                                <span class="text-white text-sm w-6 text-center font-medium">@item.Cantidad</span>
                                <button @onclick="() => CambiarCantidad(item, 1)" class="w-7 h-7 flex items-center justify-center text-gray-400 hover:text-white transition-colors text-base">+</button>
                            </div>
                            <button @onclick="() => items.Remove(item)" class="w-6 h-6 flex items-center justify-center text-gray-600 hover:text-[var(--color-danger)] transition-colors flex-shrink-0">
                                <i class="bi bi-x-lg" style="font-size:11px"></i>
                            </button>
                        </div>
                    }
                </div>

                <!-- Total -->
                <div class="mt-3 px-4 py-3 bg-[var(--color-primary)]/10 rounded-xl border border-[var(--color-primary)]/20 flex items-center justify-between">
                    <span class="text-sm font-semibold text-gray-300">TOTAL</span>
                    <span class="text-xl font-bold text-white">@TotalPresupuesto.ToString("C")</span>
                </div>
            }
        </div>
    </div>

    <div class="mt-6 pt-5 border-t border-white/10 flex justify-end gap-3">
        <button type="button" @onclick="() => isModalOpen = false" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors font-medium">Cancelar</button>
        <button type="submit"
                disabled="@(!items.Any() || isSaving)"
                class="px-6 py-2.5 rounded-xl bg-[var(--color-primary)] hover:brightness-110 text-white transition-all font-medium disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
            @if (isSaving)
            {
                <i class="bi bi-arrow-repeat animate-spin"></i>
                <span>Generando PDF...</span>
            }
            else
            {
                <i class="bi bi-file-earmark-pdf-fill"></i>
                <span>Guardar y Descargar PDF</span>
            }
        </button>
    </div>
    </EditForm>
</AppModal>

<!-- Modal Eliminar -->
<AppModal IsOpen="isDeleteModalOpen" IsOpenChanged="(v) => isDeleteModalOpen = v" Title="Eliminar Presupuesto">
    <div class="py-4">
        <p class="text-gray-300">¿Eliminar el presupuesto <strong>#@deletingItem?.NumeroPresupuesto.ToString("D6")</strong>?</p>
        <p class="text-sm text-[var(--color-danger)] mt-2"><i class="bi bi-exclamation-triangle-fill mr-1"></i> Esta acción no se puede deshacer.</p>
    </div>
    <div class="mt-6 flex justify-end gap-3">
        <button @onclick="() => isDeleteModalOpen = false" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors font-medium">Cancelar</button>
        <button @onclick="ConfirmEliminar" class="px-5 py-2.5 rounded-xl bg-[var(--color-danger)] hover:brightness-110 text-white transition-all font-medium">Eliminar</button>
    </div>
</AppModal>

@code {
    private List<Presupuesto> presupuestos = new();
    private List<Producto> productos = new();
    private List<Cliente> clientes = new();
    private bool isLoading = true;

    // Modal nuevo
    private bool isModalOpen = false;
    private bool isSaving = false;
    private string productSearch = "";
    private Presupuesto nuevoPresupuesto = new();

    private class ItemPresupuesto
    {
        public Guid ProductoId { get; set; }
        public string Nombre { get; set; } = "";
        public decimal PrecioUnitario { get; set; }
        public int Cantidad { get; set; } = 1;
        public decimal Subtotal => PrecioUnitario * Cantidad;
    }
    private List<ItemPresupuesto> items = new();
    private decimal TotalPresupuesto => items.Sum(i => i.Subtotal);

    private IEnumerable<Producto> ProductosFiltrados => string.IsNullOrWhiteSpace(productSearch)
        ? productos
        : productos.Where(p => p.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
                             || p.SKU.Contains(productSearch, StringComparison.OrdinalIgnoreCase));

    // Modal eliminar
    private bool isDeleteModalOpen = false;
    private Presupuesto? deletingItem;

    // Descarga
    private Guid? downloadingId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        presupuestos = await Data.GetPresupuestosAsync();
        productos = (await Data.GetProductosAsync()).OrderBy(p => p.Name).ToList();
        clientes = (await Data.GetClientesAsync()).OrderBy(c => c.Name).ToList();
        isLoading = false;
    }

    private string GetClienteName(Guid? id)
    {
        if (!id.HasValue) return "";
        return clientes.FirstOrDefault(c => c.Id == id.Value)?.Name ?? "";
    }

    private void OpenNuevo()
    {
        items.Clear();
        productSearch = "";
        nuevoPresupuesto = new Presupuesto { Notas = "" };
        isModalOpen = true;
    }

    private void AgregarProducto(Producto p)
    {
        var existing = items.FirstOrDefault(i => i.ProductoId == p.Id);
        if (existing != null)
            existing.Cantidad++;
        else
            items.Add(new ItemPresupuesto { ProductoId = p.Id, Nombre = p.Name, PrecioUnitario = p.Price });
    }

    private void CambiarCantidad(ItemPresupuesto item, int delta)
    {
        var nueva = item.Cantidad + delta;
        if (nueva <= 0) items.Remove(item);
        else item.Cantidad = nueva;
    }

    private async Task GuardarYDescargarAsync()
    {
        if (!items.Any() || isSaving) return;
        isSaving = true;
        try
        {
            var detalles = items.Select(i => new PresupuestoDetalle
            {
                ProductoId = i.ProductoId,
                Quantity = i.Cantidad,
                UnitPrice = i.PrecioUnitario
            }).ToList();

            var saved = await Data.SavePresupuestoAsync(nuevoPresupuesto, detalles);

            await GenerarYGuardarPdfAsync(saved, detalles);

            isModalOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Notifications.Error($"Error al guardar presupuesto: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DescargarPdfAsync(Presupuesto presupuesto)
    {
        downloadingId = presupuesto.Id;
        StateHasChanged();
        try
        {
            var detalles = await Data.GetPresupuestoDetallesAsync(presupuesto.Id);
            await GenerarYGuardarPdfAsync(presupuesto, detalles);
        }
        catch (Exception ex)
        {
            Notifications.Error($"Error al generar PDF: {ex.Message}");
        }
        finally
        {
            downloadingId = null;
        }
    }

    private async Task GenerarYGuardarPdfAsync(Presupuesto presupuesto, List<PresupuestoDetalle> detalles)
    {
        var config = await Data.GetConfiguracionAsync() ?? new ConfiguracionApp();
        Cliente? cliente = presupuesto.ClienteId.HasValue
            ? clientes.FirstOrDefault(c => c.Id == presupuesto.ClienteId.Value)
            : null;

        var nombreProductos = productos.ToDictionary(p => p.Id, p => p.Name);

        var data = new PresupuestoData
        {
            Presupuesto = presupuesto,
            Detalles = detalles,
            NombreProductos = nombreProductos,
            Cliente = cliente,
            Config = config
        };

        var pdfBytes = PdfSvc.GenerarPresupuesto(data);
        using var stream = new MemoryStream(pdfBytes);
        var fileName = $"Presupuesto_{presupuesto.NumeroPresupuesto:D6}_{presupuesto.Date:yyyyMMdd}.pdf";

        var result = await MainThread.InvokeOnMainThreadAsync(async () =>
            await CommunityToolkit.Maui.Storage.FileSaver.Default.SaveAsync(fileName, stream));

        if (result.IsSuccessful)
            Notifications.Success($"Presupuesto #{presupuesto.NumeroPresupuesto:D6} guardado.");
        else
            Notifications.Error("No se pudo guardar el PDF.");
    }

    private void OpenEliminar(Presupuesto p)
    {
        deletingItem = p;
        isDeleteModalOpen = true;
    }

    private async Task ConfirmEliminar()
    {
        if (deletingItem == null) return;
        try
        {
            await Data.DeletePresupuestoAsync(deletingItem.Id);
            Notifications.Success($"Presupuesto #{deletingItem.NumeroPresupuesto:D6} eliminado.");
            isDeleteModalOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Notifications.Error($"Error al eliminar: {ex.Message}");
            isDeleteModalOpen = false;
        }
    }
}
