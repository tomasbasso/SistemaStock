@page "/configuracion"
@inject DataService Data
@inject NotificationService Notifications
@inject Sistema_de_Stock.Services.BackupService Backup

<div class="max-w-3xl">
    <div>
        <h2 class="page-title mb-1">Configuración del Sistema</h2>
        <p class="page-subtitle mb-8">Administra los parámetros generales del negocio</p>
    </div>

    @if (isLoading)
    {
        <div class="animate-pulse space-y-4 premium-card p-6">
            <div class="h-10 bg-white/5 rounded w-full"></div>
            <div class="h-10 bg-white/5 rounded w-full"></div>
            <div class="h-10 bg-white/5 rounded w-1/2"></div>
        </div>
    }
    else
    {
        <div class="premium-card p-8">
            <form @onsubmit="SaveConfig">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    
                    <!-- Nombre Negocio -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Nombre del Negocio</label>
                        <input type="text" @bind="config.NombreNegocio" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" required />
                    </div>

                    <!-- Moneda -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Moneda (Símbolo)</label>
                        <input type="text" @bind="config.Moneda" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" required />
                    </div>

                    <!-- Teléfono -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Teléfono</label>
                        <input type="text" @bind="config.Telefono" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                    </div>

                    <!-- Dirección -->
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Dirección Completa</label>
                        <input type="text" @bind="config.DireccionNegocio" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                    </div>

                </div>

                <div class="flex justify-end pt-4 border-t border-white/5">
                    <button type="submit" class="bg-[var(--color-primary)] hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center gap-2" disabled="@isSaving">
                        @if(isSaving)
                        {
                            <i class="bi bi-hourglass-split animate-spin"></i>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="bi bi-save2"></i>
                            <span>Guardar Cambios</span>
                        }
                    </button>
                </div>
            </form>

            @if (showSuccessMessage)
            {
                <div class="mt-4 p-4 rounded-xl bg-[var(--color-success)]/20 border border-[var(--color-success)]/30 text-[var(--color-success-foreground)] flex items-center gap-3 animate-fade-in">
                    <i class="bi bi-check-circle-fill text-xl"></i>
                    <span>La configuración se ha guardado correctamente. Los cambios en el menú se verán al reiniciar.</span>
                </div>
            }
        </div>

        <div class="premium-card p-8 mt-6">
            <h3 class="text-xl font-bold text-white flex items-center gap-2 border-b border-white/5 pb-4 mb-6">
                <i class="bi bi-database-check text-[var(--color-primary)]"></i>
                Respaldo de Base de Datos
            </h3>
            
            <p class="text-gray-400 mb-6 text-sm">
                Genera una copia de seguridad de todos los datos <b>(stock.db)</b> o restaura un respaldo previo. 
                <i>Se recomienda hacer backups periódicos.</i>
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
                <button @onclick="ExportarBackup" disabled="@isBackuping" class="flex-1 bg-white/5 border border-white/10 hover:bg-[var(--color-primary)] text-white font-medium py-3 px-6 rounded-xl transition-all shadow-sm flex items-center justify-center gap-3">
                    @if (isBackuping)
                    {
                        <i class="bi bi-arrow-repeat animate-spin"></i>
                        <span>Generando...</span>
                    }
                    else
                    {
                        <i class="bi bi-cloud-download"></i>
                        <span>Exportar Backup</span>
                    }
                </button>
                <button @onclick="RestaurarBackup" disabled="@isBackuping" class="flex-1 bg-white/5 border border-white/10 hover:bg-[var(--color-warning)] text-white font-medium py-3 px-6 rounded-xl transition-all shadow-sm flex items-center justify-center gap-3">
                    <i class="bi bi-cloud-upload"></i>
                    <span>Restaurar Backup</span>
                </button>
            </div>
            
            @if (!string.IsNullOrEmpty(backupMessage))
            {
                <div class="mt-4 text-sm text-[var(--color-success)] py-2 border border-[var(--color-success)]/20 rounded-lg px-4 bg-[var(--color-success)]/10 text-center animate-fade-in">
                    @backupMessage
                </div>
            }
        </div>
    }

</div>

@code {
    private ConfiguracionApp config = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showSuccessMessage = false;

    // Backup vars
    private bool isBackuping = false;
    private string backupMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadConfig();
    }

    private async Task LoadConfig()
    {
        isLoading = true;
        config = await Data.GetConfiguracionAsync() ?? new ConfiguracionApp();
        isLoading = false;
    }

    private async Task SaveConfig()
    {
        isSaving = true;
        showSuccessMessage = false;
        try
        {
            await Data.SaveConfiguracionAsync(config);
            await Task.Delay(300);
            isSaving = false;
            showSuccessMessage = true;
            Notifications.Success("Configuración guardada correctamente.");
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                showSuccessMessage = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            isSaving = false;
            Notifications.Error($"Error al guardar: {ex.Message}");
        }
    }

    private async Task ExportarBackup()
    {
        isBackuping = true;
        backupMessage = "";
        StateHasChanged();

        var result = await Backup.ExportBackupAsync();
        if (result.Success)
        {
            backupMessage = "¡Respaldo exportado exitosamente!";
            Notifications.Success("Backup generado.");
        }
        else
        {
            Notifications.Error(result.Message);
        }

        isBackuping = false;
        StateHasChanged();
        
        // Hide message after a few seconds
        if (result.Success)
        {
            await Task.Delay(3000);
            backupMessage = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RestaurarBackup()
    {
        isBackuping = true;
        backupMessage = "";
        StateHasChanged();

        var result = await Backup.RestoreBackupAsync();
        if (result.Success)
        {
            backupMessage = "¡IMPORTANTE! Base de datos restaurada. CIERRA Y ABRE la aplicación para ver los nuevos datos.";
            Notifications.Success("Base de datos restaurada.");
        }
        else
        {
            Notifications.Error($"Error al restaurar: {result.Message}");
        }

        isBackuping = false;
        StateHasChanged();
    }
}
