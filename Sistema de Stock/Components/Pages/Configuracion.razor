@page "/configuracion"
@inject DataService Data
@inject NotificationService Notifications
@inject Sistema_de_Stock.Services.BackupService Backup
@using CommunityToolkit.Maui.Storage
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Storage
@using Microsoft.Maui.Controls
@using System.IO

<div class="max-w-3xl">
    <div>
        <h2 class="page-title mb-1">Configuración del Sistema</h2>
        <p class="page-subtitle mb-8">Administra los parámetros generales del negocio</p>
    </div>

    @if (isLoading)
    {
        <div class="animate-pulse space-y-4 premium-card p-6">
            <div class="h-10 bg-white/5 rounded w-full"></div>
            <div class="h-10 bg-white/5 rounded w-full"></div>
            <div class="h-10 bg-white/5 rounded w-1/2"></div>
        </div>
    }
    else
    {
        <div class="premium-card p-8">
            <EditForm Model="config" OnValidSubmit="SaveConfig">
                <DataAnnotationsValidator />
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    
                    <!-- Nombre Negocio -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Nombre del Negocio</label>
                        <InputText @bind-Value="config.NombreNegocio" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                        <ValidationMessage For="() => config.NombreNegocio" class="text-[var(--color-danger)] text-sm mt-1" />
                    </div>

                    <!-- Moneda -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Moneda (Símbolo)</label>
                        <InputText @bind-Value="config.Moneda" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                        <ValidationMessage For="() => config.Moneda" class="text-[var(--color-danger)] text-sm mt-1" />
                    </div>

                    <!-- Teléfono -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Teléfono</label>
                        <InputText @bind-Value="config.Telefono" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                        <ValidationMessage For="() => config.Telefono" class="text-[var(--color-danger)] text-sm mt-1" />
                    </div>

                    <!-- Dirección -->
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Dirección Completa</label>
                        <InputText @bind-Value="config.DireccionNegocio" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
                        <ValidationMessage For="() => config.DireccionNegocio" class="text-[var(--color-danger)] text-sm mt-1" />
                    </div>

                </div>

                <div class="flex justify-end pt-4 border-t border-white/5">
                    <button type="submit" class="bg-[var(--color-primary)] hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center gap-2" disabled="@isSaving">
                        @if(isSaving)
                        {
                            <i class="bi bi-hourglass-split animate-spin"></i>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="bi bi-save2"></i>
                            <span>Guardar Cambios</span>
                        }
                    </button>
                </div>
            </EditForm>

            @if (showSuccessMessage)
            {
                <div class="mt-4 p-4 rounded-xl bg-[var(--color-success)]/20 border border-[var(--color-success)]/30 text-[var(--color-success-foreground)] flex items-center gap-3 animate-fade-in">
                    <i class="bi bi-check-circle-fill text-xl"></i>
                    <span>La configuración se ha guardado correctamente. Los cambios en el menú se verán al reiniciar.</span>
                </div>
            }
        </div>

        <div class="premium-card p-8 mt-6">
            <h3 class="text-xl font-bold text-white flex items-center gap-2 border-b border-white/5 pb-4 mb-6">
                <i class="bi bi-database-check text-[var(--color-primary)]"></i>
                Respaldo de Base de Datos
            </h3>
            
            <p class="text-gray-400 mb-6 text-sm">
                Los respaldos se guardan en una carpeta local (por ejemplo, sincronizada con Google Drive Desktop) manteniendo los últimos 15 archivos. El sistema intentará uno automático cada 24h mientras la app esté abierta.
            </p>

            <div class="grid gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Carpeta de respaldo</label>
                    <div class="flex flex-col md:flex-row gap-3">
                        <input type="text" class="flex-1 bg-black/20 border border-white/10 rounded-xl px-4 py-3 text-white text-sm" value="@selectedFolderDisplay" readonly />
                        <button type="button" class="bg-white/10 hover:bg-white/20 border border-white/10 text-white font-medium px-4 py-3 rounded-xl transition-all flex items-center gap-2" @onclick="SeleccionarCarpeta">
                            <i class="bi bi-folder2-open"></i>
                            <span>Seleccionar Carpeta</span>
                        </button>
                    </div>
                    <p class="text-xs text-gray-400 mt-2">Se recomienda elegir una carpeta sincronizada por Google Drive Desktop.</p>
                </div>

                <div class="flex items-center gap-2 text-sm text-gray-300">
                    <i class="bi bi-clock-history text-[var(--color-primary)]"></i>
                    <span>Último respaldo histórico: <strong>@lastBackupText</strong></span>
                </div>
                <div class="flex items-center gap-2 text-sm text-gray-300">
                    <i class="bi bi-calendar-check text-[var(--color-success)]"></i>
                    <span>Último backup de cierre: <strong>@lastClosingBackupText</strong></span>
                </div>

                <div class="flex flex-col sm:flex-row gap-3">
                    <button type="button" class="flex-1 bg-[var(--color-primary)] hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" @onclick="RespaldarAhora" disabled="@(!canBackup || isBackingUp || isRestoring)">
                        @if (isBackingUp)
                        {
                            <i class="bi bi-arrow-repeat animate-spin"></i>
                            <span>Generando respaldo...</span>
                        }
                        else
                        {
                            <i class="bi bi-hdd-network"></i>
                            <span>Respaldar ahora</span>
                        }
                    </button>
                    <button type="button" class="flex-1 bg-[var(--color-warning)]/80 hover:brightness-110 text-white font-medium py-3 px-6 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" @onclick="RestaurarBackup" disabled="@isRestoring">
                        @if (isRestoring)
                        {
                            <i class="bi bi-arrow-repeat animate-spin"></i>
                            <span>Restaurando...</span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-counterclockwise"></i>
                            <span>Restaurar backup</span>
                        }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(alertMessage))
                {
                    <div class="@alertCss">
                        <i class="@alertIcon"></i>
                        <span>@alertMessage</span>
                    </div>
                }
            </div>
        </div>
    }

</div>

@code {
    private ConfiguracionApp config = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showSuccessMessage = false;

    // Backup UI state
    private string selectedFolder = "";
    private string selectedFolderDisplay = "Sin carpeta seleccionada";
    private DateTime? lastBackupUtc = null;
    private string lastBackupText = "Nunca";
    private DateTime? lastClosingBackupUtc = null;
    private string lastClosingBackupText = "Nunca";
    private bool isBackingUp = false;
    private bool isRestoring = false;
    private string alertMessage = "";
    private string alertCss = "";
    private string alertIcon = "";
    private bool canBackup => !string.IsNullOrWhiteSpace(selectedFolder) && Directory.Exists(selectedFolder);

    protected override async Task OnInitializedAsync()
    {
        await LoadConfig();
        LoadBackupState();
    }

    private async Task LoadConfig()
    {
        isLoading = true;
        config = await Data.GetConfiguracionAsync() ?? new ConfiguracionApp();
        isLoading = false;
    }

    private async Task SaveConfig()
    {
        isSaving = true;
        showSuccessMessage = false;
        try
        {
            await Data.SaveConfiguracionAsync(config);
            await Task.Delay(300);
            isSaving = false;
            showSuccessMessage = true;
            Notifications.Success("Configuración guardada correctamente.");
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                showSuccessMessage = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            isSaving = false;
            Notifications.Error($"Error al guardar: {ex.Message}");
        }
    }

    private void LoadBackupState()
    {
        selectedFolder = Backup.GetConfiguredFolder() ?? string.Empty;
        selectedFolderDisplay = string.IsNullOrWhiteSpace(selectedFolder) ? "Sin carpeta seleccionada" : selectedFolder;

        lastBackupUtc = Backup.GetLastBackupUtc();
        lastBackupText = lastBackupUtc.HasValue
            ? TimeZoneInfo.ConvertTimeFromUtc(lastBackupUtc.Value, TimeZoneInfo.Local).ToString("dd/MM/yyyy HH:mm")
            : "Nunca";

        lastClosingBackupUtc = Backup.GetLastClosingBackupUtc();
        lastClosingBackupText = lastClosingBackupUtc.HasValue
            ? TimeZoneInfo.ConvertTimeFromUtc(lastClosingBackupUtc.Value, TimeZoneInfo.Local).ToString("dd/MM/yyyy HH:mm")
            : "Nunca";
    }

    private async Task SeleccionarCarpeta()
    {
        try
        {
            var pickResult = await MainThread.InvokeOnMainThreadAsync(async () =>
            {
                return await FolderPicker.Default.PickAsync("Seleccione carpeta de respaldo");
            });

            if (pickResult == null || string.IsNullOrWhiteSpace(pickResult.Folder?.Path))
                return;

            selectedFolder = pickResult.Folder.Path;
            selectedFolderDisplay = selectedFolder;

            Preferences.Set("Backup.TargetFolder", selectedFolder);
            alertMessage = "";

            Notifications.Success("Carpeta de respaldo guardada.");
        }
        catch (Exception ex)
        {
            Notifications.Error($"No se pudo seleccionar la carpeta: {ex.Message}");
        }

        StateHasChanged();
    }

    private async Task RespaldarAhora()
    {
        if (!canBackup)
        {
            Notifications.Warning("Configura primero una carpeta de respaldo.");
            return;
        }

        isBackingUp = true;
        alertMessage = "";
        StateHasChanged();

        var result = await Backup.ExecuteBackupToFolderAsync(selectedFolder, isAutomatic: false);

        isBackingUp = false;

        if (result.Success)
        {
            Notifications.Success("Backup creado correctamente.");
            lastBackupUtc = DateTime.UtcNow;
            lastBackupText = TimeZoneInfo.ConvertTimeFromUtc(lastBackupUtc.Value, TimeZoneInfo.Local).ToString("dd/MM/yyyy HH:mm");
            alertMessage = "Backup generado y guardado en la carpeta configurada.";
            alertCss = "mt-2 p-3 rounded-lg bg-[var(--color-success)]/15 border border-[var(--color-success)]/30 text-[var(--color-success-foreground)] flex items-center gap-2";
            alertIcon = "bi bi-check-circle-fill";
        }
        else
        {
            Notifications.Error(result.Message);
            alertMessage = result.Message;
            alertCss = "mt-2 p-3 rounded-lg bg-[var(--color-danger)]/15 border border-[var(--color-danger)]/30 text-[var(--color-danger-foreground)] flex items-center gap-2";
            alertIcon = "bi bi-exclamation-triangle-fill";
        }

        StateHasChanged();
    }

    private async Task RestaurarBackup()
    {
        isRestoring = true;
        alertMessage = "";
        StateHasChanged();

        var result = await Backup.RestoreBackupAsync();

        if (result.Success)
        {
            alertMessage = "Backup restaurado. La aplicación se cerrará en 3 segundos; si no se cierra (Android), reabrila manualmente.";
            alertCss = "mt-2 p-3 rounded-lg bg-[var(--color-success)]/15 border border-[var(--color-success)]/30 text-[var(--color-success-foreground)] flex items-center gap-2";
            alertIcon = "bi bi-check-circle-fill";
            Notifications.Success("Base de datos restaurada. Cerrando la aplicación...");
            StateHasChanged();
            await Task.Delay(3000);
            Application.Current?.Quit();
        }
        else
        {
            alertMessage = result.Message;
            alertCss = "mt-2 p-3 rounded-lg bg-[var(--color-danger)]/15 border border-[var(--color-danger)]/30 text-[var(--color-danger-foreground)] flex items-center gap-2";
            alertIcon = "bi bi-exclamation-triangle-fill";
            Notifications.Error($"Error al restaurar: {result.Message}");
        }

        isRestoring = false;
        StateHasChanged();
    }
}
