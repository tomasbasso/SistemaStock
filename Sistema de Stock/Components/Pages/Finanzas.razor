@page "/finanzas"
@using Sistema_de_Stock.Models
@using Sistema_de_Stock.Services
@using Sistema_de_Stock.Components.Shared
@inject DataService Data

<div class="max-w-7xl mx-auto">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
        <div>
            <h2 class="page-title mb-1">Caja y Finanzas</h2>
            <p class="page-subtitle">Historial de Ingresos y Egresos</p>
        </div>
        <div class="flex gap-3">
             <button @onclick="() => OpenNew(TipoMovimiento.Egreso)" class="bg-white/5 border border-white/10 hover:bg-white/10 text-[var(--color-danger)] font-medium py-2.5 px-5 rounded-xl transition-all flex items-center gap-2">
                <i class="bi bi-arrow-down-right-circle"></i>
                <span>Nuevo Egreso</span>
            </button>
            <button @onclick="() => OpenNew(TipoMovimiento.Ingreso)" class="bg-[var(--color-success)] hover:brightness-110 text-white font-medium py-2.5 px-5 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2">
                <i class="bi bi-arrow-up-right-circle"></i>
                <span>Nuevo Ingreso</span>
            </button>
        </div>
    </div>

    <!-- Summary KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="premium-card p-6 border-l-4 border-[var(--color-primary)]">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">Balance Neto</p>
            <h3 class="text-3xl font-bold text-white">@BalanceTotal.ToString("C")</h3>
        </div>
        <div class="premium-card p-6 border-l-4 border-[var(--color-success)]">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">Total Ingresos</p>
            <h3 class="text-3xl font-bold text-[var(--color-success)]">@TotalIngresos.ToString("C")</h3>
        </div>
        <div class="premium-card p-6 border-l-4 border-[var(--color-danger)]">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">Total Egresos</p>
            <h3 class="text-3xl font-bold text-[var(--color-danger)]">@TotalEgresos.ToString("C")</h3>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="premium-card p-4 mb-6 flex items-center">
        <div class="relative flex-1 max-w-md">
            <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Buscar movimientos..." class="w-full bg-black/20 border border-white/10 rounded-xl pl-12 pr-4 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)] transition-all" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="premium-card p-6 min-h-[400px] flex items-center justify-center">
            <i class="bi bi-arrow-repeat animate-spin text-4xl text-gray-500"></i>
        </div>
    }
    else if (!items.Any())
    {
        <div class="text-center py-20 bg-white/5 rounded-2xl border border-white/5 border-dashed">
            <i class="bi bi-wallet2 text-4xl text-gray-400 mb-4 block"></i>
            <h3 class="text-lg font-medium text-white mb-2">Sin Movimientos</h3>
            <p class="text-gray-400 mb-6">Aún no se ha registrado dinero en el sistema.</p>
        </div>
    }
    else
    {
        <div class="premium-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left whitespace-nowrap">
                    <thead>
                        <tr class="border-b border-white/10 bg-black/20 text-xs uppercase tracking-wider text-gray-400">
                            <th class="px-6 py-4 font-medium">Fecha</th>
                            <th class="px-6 py-4 font-medium">Descripción</th>
                            <th class="px-6 py-4 font-medium">Referencia</th>
                            <th class="px-6 py-4 font-medium text-right">Monto</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var item in items)
                        {
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4 text-sm text-gray-400">@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4">
                                    <div class="font-medium text-white flex items-center gap-2">

                                        @if(item.Type == TipoMovimiento.Ingreso)
                                        {
                                            <i class="bi bi-arrow-up-right-circle text-[var(--color-success)]"></i>
                                        }
                                        else
                                        {
                                           <i class="bi bi-arrow-down-right-circle text-[var(--color-danger)]"></i> 
                                        }
                                        <span>@item.Description</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    @(item.VentaId.HasValue ? $"Venta Ref." : "-")
                                </td>
                                <td class="px-6 py-4 font-medium text-right @(item.Type == TipoMovimiento.Ingreso ? "text-[var(--color-success)]" : "text-[var(--color-danger)]")">
                                    @(item.Type == TipoMovimiento.Ingreso ? "+" : "-") @item.Amount.ToString("C")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <AppPagination TotalItems="totalItems" PageSize="@pageSize" CurrentPage="currentPage" OnPageChanged="HandlePageChange" />
        </div>
    }

</div>

<!-- Form Modal -->
<AppModal IsOpen="isModalOpen" IsOpenChanged="(v) => isModalOpen = v" Title="@(nuevaTransaccion.Type == TipoMovimiento.Ingreso ? "Registrar Ingreso" : "Registrar Egreso")">
    <div class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Concepto / Descripción *</label>
            <input type="text" @bind="nuevaTransaccion.Description" autofocus class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" placeholder="Ej: Pago de luz, Aporte de capital..." />
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Monto *</label>
            <input type="number" step="0.01" min="0.01" @bind="nuevaTransaccion.Amount" class="w-full bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)]" />
        </div>
    </div>
    
    <div class="mt-8 flex justify-end gap-3">
        <button @onclick="() => isModalOpen = false" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-colors font-medium">Cancelar</button>
        <button @onclick="Save" disabled="@(string.IsNullOrWhiteSpace(nuevaTransaccion.Description) || nuevaTransaccion.Amount <= 0)" class="px-5 py-2.5 rounded-xl @(nuevaTransaccion.Type == TipoMovimiento.Ingreso ? "bg-[var(--color-success)]" : "bg-[var(--color-danger)]") hover:brightness-110 text-white transition-all font-medium disabled:opacity-50 disabled:cursor-not-allowed">
            Guardar
        </button>
    </div>
</AppModal>

@code {
    private List<MovimientoFinanciero> items = new();
    private bool isLoading = true;
    
    // Aggregates
    private decimal TotalIngresos = 0;
    private decimal TotalEgresos = 0;
    private decimal BalanceTotal => TotalIngresos - TotalEgresos;

    // Search & Pagination
    private int totalItems = 0;
    private int currentPage = 1;
    private int pageSize = 20;

    private string _searchQuery = "";
    private System.Timers.Timer? searchTimer;

    private string searchQuery 
    {
        get => _searchQuery;
        set 
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                if (searchTimer != null)
                {
                    searchTimer.Stop();
                    searchTimer.Start();
                }
            }
        }
    }

    private bool isModalOpen = false;
    private MovimientoFinanciero nuevaTransaccion = new();

    protected override async Task OnInitializedAsync()
    {
        searchTimer = new System.Timers.Timer(400);
        searchTimer.Elapsed += SearchTimer_Elapsed;
        searchTimer.AutoReset = false;

        await LoadData();
    }

    private void SearchTimer_Elapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        currentPage = 1;
        InvokeAsync(LoadData);
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        var totales = await Data.GetTotalesMovimientosAsync();
        TotalIngresos = totales.Ingresos;
        TotalEgresos = totales.Egresos;

        totalItems = await Data.GetTotalMovimientosAsync(searchQuery);
        items = await Data.GetMovimientosPaginadosAsync(currentPage, pageSize, searchQuery);
        
        isLoading = false;
        StateHasChanged();
    }

    private async Task HandlePageChange(int page)
    {
        currentPage = page;
        await LoadData();
    }

    private void OpenNew(TipoMovimiento type)
    {
        nuevaTransaccion = new MovimientoFinanciero { Type = type, Amount = 0 };
        isModalOpen = true;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(nuevaTransaccion.Description) || nuevaTransaccion.Amount <= 0) return;
        
        await Data.AddMovimientoAsync(nuevaTransaccion);
        isModalOpen = false;
        await LoadData();
    }
}
