@page "/variacion-precios"
@using Sistema_de_Stock.Models
@using Sistema_de_Stock.Services
@using Microsoft.Maui.Storage
@using CommunityToolkit.Maui.Storage
@inject DataService Data
@inject NotificationService Notifications
@inject ReportService Reports

<div class="max-w-7xl mx-auto">
    <div class="mb-8">
        <h2 class="page-title mb-1">Análisis de Inventario</h2>
        <p class="page-subtitle">Rotación, valor inmovilizado y variaciones de precios</p>
    </div>

    <!-- Indicador de Rotación -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="premium-card p-6 border-l-4 border-l-[var(--color-primary)]">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] text-2xl">
                    <i class="bi bi-arrow-repeat"></i>
                </div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Métrica Anual</span>
            </div>
            <h3 class="text-gray-400 text-sm font-medium mb-1">Rotación Anual del Inventario</h3>
            <div class="flex items-baseline gap-2">
                <span class="text-4xl font-bold text-white">@rotacionAnual.ToString("N2")</span>
                <span class="text-gray-500 text-sm font-medium">veces/año</span>
            </div>
            <p class="text-xs text-gray-500 mt-4 leading-relaxed line-clamp-2">
                Indica cuántas veces se renueva el stock total en un periodo de 12 meses.
            </p>
        </div>
    </div>

    <!-- Rotación por producto -->
    <div class="premium-card overflow-hidden mb-10">
        <div class="px-6 py-4 border-b border-white/10 bg-black/20 flex items-center justify-between gap-4 flex-col md:flex-row">
            <div>
                <h3 class="font-medium text-white flex items-center gap-2">
                    <i class="bi bi-speedometer2 text-gray-400"></i>
                    Rotación por producto (últimos 12 meses)
                </h3>
                <p class="text-xs text-gray-500">Detecta productos con baja rotación y capital inmovilizado.</p>
            </div>
            <div class="flex flex-wrap gap-2 w-full md:w-auto">
                <div class="relative">
                    <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" value="@searchRot" @oninput="OnSearchRotChange" placeholder="Buscar producto..."
                           class="w-full md:w-56 bg-black/20 border border-white/10 rounded-xl pl-10 pr-3 py-2 text-sm text-white focus:outline-none focus:border-[var(--color-primary)]" />
                </div>
                <select @onchange="OnCategoriaChange" class="bg-black/20 border border-white/10 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-[var(--color-primary)]">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <label class="inline-flex items-center gap-2 text-sm text-gray-300 bg-black/20 border border-white/10 rounded-xl px-3 py-2">
                    <input type="checkbox" checked="@soloBaja" @onchange="OnSoloBajaChange" class="accent-[var(--color-primary)]" />
                    Solo baja rotación
                </label>
                <button @onclick="ExportarRotacion" class="bg-white/10 hover:bg-white/15 text-white text-sm px-4 py-2 rounded-xl border border-white/10 transition-colors">
                    <i class="bi bi-file-earmark-excel"></i> Exportar Excel
                </button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead>
                    <tr class="border-b border-white/10 bg-black/10 text-xs uppercase tracking-wider text-gray-400">
                        <th class="px-6 py-4">Producto</th>
                        <th class="px-6 py-4">Categoría</th>
                        <th class="px-6 py-4 text-right">Ventas 12m</th>
                        <th class="px-6 py-4 text-right">Stock</th>
                        <th class="px-6 py-4 text-right">Rotación</th>
                        <th class="px-6 py-4 text-right">Valor inmovilizado</th>
                        <th class="px-6 py-4 text-right">Margen</th>
                        <th class="px-6 py-4 text-center">Tendencia</th>
                        <th class="px-6 py-4 text-center">Última venta</th>
                        <th class="px-6 py-4 text-center">Estado</th>
                        <th class="px-6 py-4">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (!rotaciones.Any())
                    {
                        <tr>
                            <td colspan="11" class="px-6 py-10 text-center text-gray-500">Sin datos con los filtros actuales.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in PaginatedRotaciones)
                        {
                            string estadoClass = r.EstadoRotacion switch
                            {
                                "Alta" => "bg-green-500/15 text-green-300",
                                "Media" => "bg-blue-500/15 text-blue-300",
                                "Baja" => "bg-yellow-500/15 text-yellow-300",
                                _ => "bg-red-500/15 text-red-300"
                            };
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4 text-white font-medium">@r.Nombre</td>
                                <td class="px-6 py-4 text-sm text-gray-300">@r.Categoria</td>
                                <td class="px-6 py-4 text-sm text-right text-gray-300">@r.UnidadesVendidas12m</td>
                                <td class="px-6 py-4 text-sm text-right text-gray-300">@r.StockActual</td>
                                <td class="px-6 py-4 text-sm text-right font-semibold">@r.Rotacion.ToString("N2")</td>
                                <td class="px-6 py-4 text-sm text-right text-gray-300">@r.ValorInmovilizado.ToString("C")</td>
                                <td class="px-6 py-4 text-sm text-right @(r.MargenUnitario < 0 ? "text-red-400" : "text-gray-200")">@r.MargenUnitario.ToString("P1")</td>
                                <td class="px-6 py-4 text-center text-lg">@r.Tendencia</td>
                                <td class="px-6 py-4 text-center text-sm text-gray-300">@((r.UltimaVenta?.ToString("dd/MM/yyyy")) ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold @estadoClass">@r.EstadoRotacion</span>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <div class="flex flex-wrap gap-2">
                                        <button class="px-3 py-1 rounded bg-white/10 hover:bg-white/20 text-white text-xs" @onclick='() => NotificarAccion(r, "Promocionar")'>Promoción</button>
                                        <button class="px-3 py-1 rounded bg-white/10 hover:bg-white/20 text-white text-xs" @onclick='() => NotificarAccion(r, "Ajustar precio")'>Ajustar</button>
                                        <button class="px-3 py-1 rounded bg-white/10 hover:bg-white/20 text-white text-xs" @onclick='() => NotificarAccion(r, "Revisar stock")'>Descontinuar</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="px-6 py-4 bg-black/10 border-t border-white/10">
            <AppPagination TotalItems="totalRotaciones" PageSize="@pageSize" CurrentPage="currentPage" OnPageChanged="OnPageChanged" />
        </div>
    </div>

    <!-- Tabla de Historial -->
    <div class="premium-card overflow-hidden">
        <div class="px-6 py-4 border-b border-white/10 bg-black/20 flex items-center justify-between gap-4 flex-col md:flex-row">
            <h3 class="font-medium text-white flex items-center gap-2">
                <i class="bi bi-clock-history text-gray-400"></i>
                Historial de Variaciones
            </h3>
            <div class="w-full md:max-w-sm relative">
                <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text"
                       @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Buscar por producto o fecha (dd/mm/aaaa)..."
                       class="w-full bg-black/20 border border-white/10 rounded-xl pl-12 pr-4 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" />
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead>
                    <tr class="border-b border-white/10 bg-black/10 text-xs uppercase tracking-wider text-gray-400">
                        <th class="px-6 py-4 font-medium">Fecha</th>
                        <th class="px-6 py-4 font-medium">Producto</th>
                        <th class="px-6 py-4 font-medium text-right">Precio Anterior</th>
                        <th class="px-6 py-4 font-medium text-right">Precio Nuevo</th>
                        <th class="px-6 py-4 font-medium text-center">Variación</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (filteredHistorial == null || !filteredHistorial.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                <i class="bi bi-info-circle mb-2 text-2xl block"></i>
                                No hay registros que coincidan con tu búsqueda.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var registro in filteredHistorial)
                        {
                            var diff = registro.PrecioNuevo - registro.PrecioAnterior;
                            var pct = registro.PrecioAnterior > 0 ? (diff / registro.PrecioAnterior) * 100 : 0;
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4 text-sm text-gray-400">@registro.FechaModificacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 font-medium text-white">@registro.ProductoNombre</td>
                                <td class="px-6 py-4 text-sm text-right text-gray-400">@registro.PrecioAnterior.ToString("C")</td>
                                <td class="px-6 py-4 text-sm text-right text-white font-medium">@registro.PrecioNuevo.ToString("C")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @(diff >= 0 ? "bg-green-500/10 text-green-400" : "bg-red-500/10 text-red-400")">
                                        <i class="bi @(diff >= 0 ? "bi-caret-up-fill" : "bi-caret-down-fill") mr-1"></i>
                                        @Math.Abs(pct).ToString("N1")%
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private double rotacionAnual;
    private List<HistorialPrecio> historial = new();
    private string searchQuery = string.Empty;
    private IEnumerable<HistorialPrecio> filteredHistorial => string.IsNullOrWhiteSpace(searchQuery)
        ? historial
        : historial.Where(h =>
            (h.ProductoNombre?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
            h.FechaModificacion.ToString("dd/MM/yyyy").Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private List<RotacionProductoDto> rotaciones = new();
    private List<Categoria> categorias = new();
    private Guid? filtroCategoria = null;
    private string searchRot = string.Empty;
    private bool soloBaja = false;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalRotaciones = 0;
    private IEnumerable<RotacionProductoDto> PaginatedRotaciones => rotaciones
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        rotacionAnual = await Data.CalcularRotacionAnualAsync();
        historial = await Data.GetHistorialPreciosAsync();
        categorias = await Data.GetCategoriasAsync();
        await LoadRotaciones();
    }

    private async Task LoadRotaciones()
    {
        rotaciones = await Data.GetRotacionProductosAsync(filtroCategoria == Guid.Empty ? null : filtroCategoria, searchRot, soloBaja, 200);
        totalRotaciones = rotaciones.Count;
        currentPage = 1;
        StateHasChanged();
    }

    private async Task OnCategoriaChange(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var catId))
            filtroCategoria = catId;
        else
            filtroCategoria = null;
        await LoadRotaciones();
    }

    private Task OnPageChanged(int page)
    {
        currentPage = page;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnSoloBajaChange(ChangeEventArgs e)
    {
        soloBaja = e.Value is bool b && b;
        await LoadRotaciones();
    }

    private async Task ExportarRotacion()
    {
        try
        {
            var data = await Data.GetRotacionProductosAsync(filtroCategoria, searchRot, soloBaja, 1000);
            var bytes = Reports.GenerateInventoryRotationReport(data);
            using var stream = new MemoryStream(bytes);
            string fileName = $"RotacionProductos_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            var result = await FileSaver.Default.SaveAsync(fileName, stream);
            if (result.IsSuccessful)
                Notifications.Success("Excel exportado correctamente.");
            else if (!result.Exception?.Message.Contains("cancel", StringComparison.OrdinalIgnoreCase) ?? true)
                Notifications.Error("No se pudo guardar el archivo.");
        }
        catch (Exception ex)
        {
            Notifications.Error($"Error al exportar: {ex.Message}");
        }
    }

    private void NotificarAccion(RotacionProductoDto dto, string accion)
    {
        Notifications.Success($"{accion} para {dto.Nombre} (rotación {dto.Rotacion:N2})");
    }

    private async Task OnSearchRotChange(ChangeEventArgs e)
    {
        searchRot = e.Value?.ToString() ?? string.Empty;
        await LoadRotaciones();
    }
}
